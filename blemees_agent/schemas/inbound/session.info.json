{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/inbound/session.info.json",
  "title": "session.info",
  "description": "Fetch one session's detail (live or registry-backed). Replied with session.info_reply.",
  "type": "object",
  "properties": {
    "type": { "const": "session.info" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" }
  },
  "required": ["type", "session_id"],
  "additionalProperties": false
}
