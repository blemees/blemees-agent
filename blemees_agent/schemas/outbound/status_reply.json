{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/status_reply.json",
  "title": "status_reply",
  "description": "Reply to status: a daemon-wide snapshot. `attention` is the outstanding needs_attention set (#24); `sessions` aggregates counts; `config` echoes effective limits.",
  "type": "object",
  "properties": {
    "type": { "const": "status_reply" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "daemon": { "type": "string" },
    "protocol": { "const": "blemees/3" },
    "pid": { "type": "integer", "minimum": 0 },
    "uptime_s": { "type": "number", "minimum": 0 },
    "socket_path": { "type": "string" },
    "agents": { "type": "object", "additionalProperties": { "type": "string" } },
    "profiles": { "type": "array", "items": { "type": "object" } },
    "connections": { "type": "integer", "minimum": 0 },
    "sessions": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "attached": { "type": "integer", "minimum": 0 },
        "detached": { "type": "integer", "minimum": 0 },
        "active_turns": { "type": "integer", "minimum": 0 },
        "by_backend": { "type": "object", "additionalProperties": { "type": "integer" } }
      },
      "additionalProperties": true
    },
    "attention": {
      "type": "array",
      "items": { "$ref": "https://blemees/schemas/_common.json#/$defs/Notification" }
    },
    "config": { "type": "object", "additionalProperties": true }
  },
  "required": ["type"],
  "additionalProperties": true
}
