{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/session.taken.json",
  "title": "session.taken",
  "description": "Pushed to the prior owner when another connection takes over the session as owner (#19). `by_peer_pid` is the new owner's PID when available.",
  "type": "object",
  "properties": {
    "type": { "const": "session.taken" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "by_peer_pid": { "$ref": "https://blemees/schemas/_common.json#/$defs/PeerPid" }
  },
  "required": ["type", "session_id"],
  "additionalProperties": true
}
