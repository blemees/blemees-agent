{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/replay_gap.json",
  "title": "replay_gap",
  "description": "Emitted during replay when the ring buffer has rolled past the client's last_seen_seq: frames in (since_seq, first_available_seq) are gone. Carries its own seq.",
  "type": "object",
  "properties": {
    "type": { "const": "replay_gap" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "since_seq": { "type": "integer", "minimum": 0 },
    "first_available_seq": { "type": "integer", "minimum": 1 },
    "seq": { "$ref": "https://blemees/schemas/_common.json#/$defs/Seq" }
  },
  "required": ["type", "session_id", "since_seq", "first_available_seq"],
  "additionalProperties": true
}
