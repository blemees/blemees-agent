{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/profile.started.json",
  "title": "profile.started",
  "description": "Reply to profile.start. `agents_started` is how many of the profile's agent processes were launched.",
  "type": "object",
  "properties": {
    "type": { "const": "profile.started" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "name": { "$ref": "https://blemees/schemas/_common.json#/$defs/ProfileName" },
    "agents_started": { "type": "integer", "minimum": 0 }
  },
  "required": ["type", "name"],
  "additionalProperties": true
}
